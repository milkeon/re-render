{
  "name": "re-render",
  "version": "0.1.1",
  "private": true,
  "description": "실행 중인 실제 창을 선택해 미니맵으로 영역을 다시 잡아 크게 보여주는 데스크톱 앱.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "package": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^32.2.0",
    "electron-builder": "^25.1.8",
    "ws": "^8.21.0"
  },
  "author": "milkeon",
  "build": {
    "appId": "com.milkeon.rerender",
    "productName": "re:render",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html"
    ],
    "linux": {
      "target": [
        "dir"
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "portable"
      ]
    }
  }
}

